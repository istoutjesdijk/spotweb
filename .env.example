# Environment for the standalone deployment (deploy/standalone).
# Copy this file to ".env" next to the compose file and adjust the values.

# Host port for the Spotweb web UI (maps to container port 8080).
SPOTWEB_PORT=8081

# Timezone.
TZ=Europe/Amsterdam

# Database credentials, shared by the db service and Spotweb.
MYSQL_DATABASE=spotweb
MYSQL_USER=spotweb
MYSQL_PASSWORD=change-me

# Spot retrieval schedule (cron expression). Leave empty to disable.
SPOTWEB_CRON_RETRIEVE=*/15 * * * *

# Watchtower poll interval in seconds (docker-compose.watchtower.yml only).
WATCHTOWER_POLL_INTERVAL=3600

# Override the image, e.g. to pin a date tag or test a local build.
# SPOTWEB_IMAGE=ghcr.io/istoutjesdijk/spotweb:latest
